# ============================================================
# Saarthi-AI Backend — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to Git
# ============================================================

# ── Firebase ─────────────────────────────────────────────────
# Option A: File path (local development)
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# Option B: Base64 encoded (Railway/Docker production)
# Generate with: base64 serviceAccountKey.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Get from Firebase Console -> Storage -> gs://YOUR-BUCKET.appspot.com
FIREBASE_STORAGE_BUCKET=saarthi-ai.appspot.com

# ── JWT Security ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_TTL_HOURS=12

# ── Razorpay ──────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com -> Settings -> API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Get from: Razorpay Dashboard -> Settings -> Webhooks -> Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Meta WhatsApp Cloud API ───────────────────────────────────
# Get from: https://developers.facebook.com -> WhatsApp -> API Setup
META_ACCESS_TOKEN=your_meta_permanent_access_token
META_API_VERSION=v19.0

# Must match what you set in Meta webhook configuration
WHATSAPP_VERIFY_TOKEN=saarthi_verify_token_change_this

# ── Google Gemini AI ──────────────────────────────────────────
# Get from: https://aistudio.google.com -> Get API Key
GEMINI_API_KEY=your_gemini_api_key

# ── Firebase Cloud Messaging (FCM) ───────────────────────────
# Get from: Firebase Console -> Project Settings -> Cloud Messaging -> Server key
FCM_SERVER_KEY=AAAA_your_fcm_legacy_server_key

# ── App Config ────────────────────────────────────────────────
# Your production domain (no trailing slash)
APP_BASE_URL=https://saarthi-ai-api.railway.app

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=https://saarthi-ai.in,https://saarthi-ai-api.railway.app

# ── Cron Security ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=REPLACE_WITH_RANDOM_STRING
# ── Cloudinary (Free PDF Invoice Storage) ────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
