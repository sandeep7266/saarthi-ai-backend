rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Block all direct client access ────────────────────────────────────────
    // Backend uses Admin SDK which bypasses these rules.
    // This prevents anyone from directly reading invoices or backups.

    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ── Invoice PDFs: allow signed URL read only ───────────────────────────────
    // Signed URLs are generated by backend with expiry — no rule needed.
    // This is just for documentation.

    // match /invoices/{clientId}/{filename} {
    //   allow read: if false;  // Use signed URLs only
    //   allow write: if false; // Backend Admin SDK only
    // }
  }
}
